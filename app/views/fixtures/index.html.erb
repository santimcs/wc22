<p id="notice"><%= notice %></p>
<% content_for :title, 'Fixtures' %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <h1>World Cup <%= @current_year %> Fixtures</h1>
  
  <div>
    <a href="/fixtures?year=2022" style="margin-right: 10px; padding: 8px 16px; background-color: #550065; color: white; text-decoration: none; border-radius: 4px;">2022 Fixtures</a>
    <a href="/fixtures?year=2026" style="padding: 8px 16px; background-color: #4CAF50; color: white; text-decoration: none; border-radius: 4px;">2026 Fixtures</a>
  </div>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Round</th>
      <th>Date</th>
      <th>Session</th>
      <th>Home</th>
      <th></th>
      <th>Away</th>
      <th>Channel</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @fixtures.each do |fixture| %>
      <tr>
        <td><%= fixture.round.name if fixture.round %></td>
        <td><%= fixture.date.strftime("%a, %b %d") if fixture.date %></td>
        <td><%= fixture.session.format_time if fixture.session %></td>
        <td>
          <% if fixture.home %>
            <img src="<%= flag_url(fixture.home.name) %>" width="30" height="15" style="margin-right: 5px;" />
            <%= fixture.home.name %>
          <% end %>
        </td>
        <td>vs</td>
        <td>
          <% if fixture.away %>
            <img src="<%= flag_url(fixture.away.name) %>" width="30" height="15" style="margin-right: 5px;" />
            <%= fixture.away.name %>
          <% end %>
        </td>
        <td><%= fixture.channel.name if fixture.channel %></td>
        <td>
          <%= link_to 'Show', fixture %>
          <%= link_to 'Edit', edit_fixture_path(fixture) %>
          <%= link_to 'Destroy', fixture, method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>