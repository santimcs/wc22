<p id="notice"><%= notice %></p>
<% content_for :title, 'Matches' %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <h1>World Cup <%= @current_year %> Matches</h1>
  
  <div>
    <a href="/list_fixtures?year=2022" style="margin-right: 10px; padding: 8px 16px; background-color: #550065; color: white; text-decoration: none; border-radius: 4px;">2022 Matches</a>
    <a href="/list_fixtures?year=2026" style="padding: 8px 16px; background-color: #4CAF50; color: white; text-decoration: none; border-radius: 4px;">2026 Matches</a>
  </div>
</div>

<% if @current_year == 2026 %>
  <div style="background-color: #e7f3ff; border-left: 4px solid #2196F3; padding: 15px; margin-bottom: 20px;">
    <strong>📢 New Format:</strong> 104 matches (up from 64 in 2022)
  </div>
<% end %>

<table id="matches" class="table table-striped table-hover">  
  <thead>
    <tr>
      <th>Round</th>
      <th>Date & Time</th>
      <th>Home</th>
      <th></th>
      <th>Result</th>
      <th>Away</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @fixtures.each do |fixture| %>
      <tr>
        <td><%= fixture.round.name if fixture.round %></td>
        <td>
          <%= fixture.date.strftime("%b %d") if fixture.date %><br>
          <%= fixture.session.format_time if fixture.session %>
         </td>
        <td>
        <% if fixture.home %>
          <%= fixture.home.name + + " (" + fixture.home.group + ")" %>
        <% end %>
        </td>
        <td>
        <% if fixture.home %>
          <img src="<%= flag_url(fixture.home.name) %>" width="30" height="15" style="margin-right: 5px;" />
        <% end %>
        </td>         
        <% @result = Result.find_by_fixture_id(fixture.id) %>
        <% if @result != nil %>  
          <td align="center" style="font-weight: bold;"><%= @result.home_goals.to_s + ' - ' + @result.away_goals.to_s %></td> 
        <% else %>
          <td align="center">vs</td>    
        <% end %>
        <td>
          <% if fixture.away %>
            <img src="<%= flag_url(fixture.away.name) %>" width="30" height="15" style="margin-right: 5px;" />
            <%= fixture.away.name  + " (" + fixture.away.group + ")" %>
          <% end %>
         </td>
        <td>
          <%= link_to 'Edit', edit_fixture_path(fixture, year: @current_year), style: "color: #4CAF50; text-decoration: none; margin-right: 10px;" %>
          <%= link_to 'Result', new_result_path(fixture_id: fixture.id), style: "color: #2196F3; text-decoration: none; margin-right: 10px;" if @result.nil? %>
          <%= link_to 'View', fixture_path(fixture, year: @current_year), style: "color: #550065; text-decoration: none;" %>
        </td>
      </td>
    <% end %>
  </tbody>