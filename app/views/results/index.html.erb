<p id="notice"><%= notice %></p>
<% content_for :title, 'Results' %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <h1>World Cup <%= @current_year %> Results</h1>
  
  <div>
    <a href="/results?year=2022" style="margin-right: 10px; padding: 8px 16px; background-color: #550065; color: white; text-decoration: none; border-radius: 4px;">2022 Results</a>
    <a href="/results?year=2026" style="padding: 8px 16px; background-color: #4CAF50; color: white; text-decoration: none; border-radius: 4px;">2026 Results</a>
  </div>
</div>

<table id="results" class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Date</th>
      <th>Home Team</th>
      <th>Result</th>
      <th>Away Team</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @results.each do |result| %>
      <tr>
        <td><%= result.fixture.date.strftime("%b %d, %Y") if result.fixture.date %></td>
        <td>
          <img src="<%= flag_url(result.fixture.home.name) %>" width="30" height="15" style="margin-right: 5px;" />
          <%= result.fixture.home.name %>
        </td>
        <td style="text-align: center; font-weight: bold;"><%= result.home_goals %> - <%= result.away_goals %></td>
        <td>
          <img src="<%= flag_url(result.fixture.away.name) %>" width="30" height="15" style="margin-right: 5px;" />
          <%= result.fixture.away.name %>
        </td>
        <td>
          <%= link_to 'Show', result %>
          <%= link_to 'Edit', edit_result_path(result) %>
          <%= link_to 'Destroy', result, method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>


