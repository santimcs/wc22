<p id="notice"><%= notice %></p>
<% content_for :title, 'Teams' %>

<h1>World Cup <%= @current_year %> Teams</h1>

<div style="margin-bottom: 20px;">
  <a href="/teams?year=2022" style="margin-right: 10px; padding: 8px 16px; background-color: #550065; color: white; text-decoration: none; border-radius: 4px;">2022 World Cup</a>
  <a href="/teams?year=2026" style="padding: 8px 16px; background-color: #4CAF50; color: white; text-decoration: none; border-radius: 4px;">2026 World Cup</a>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Group</th>
      <th>Flag</th>
    </tr>
  </thead>

  <tbody>
    <% @teams.each do |team| %>
      <tr>
        <td><a href="https://en.m.wikipedia.org/wiki/<%= @current_year %>_FIFA_World_Cup_squads#<%= CGI.escape(team.name.tr(' ', '_')) %>" target="_blank"><%= team.name %></a></td>
        <td><%= team.group %></td>
        <td><img src="<%= flag_url(team.name) %>" width="70" height="35" onerror="this.src='https://via.placeholder.com/70x35?text=Flag'" /></td>
      </tr>
    <% end %>
  </tbody>